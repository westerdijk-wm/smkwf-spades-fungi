rule genomics_db_import:
    input:
        gvcfs=expand(
            "results/called/{sample}.g.vcf.gz", sample=samples.index
        ),
        interval_list="resources/intervals.list",
    output:
        db=directory("results/genomicsdb"),
    # conda:
    #     "envs/variant.yaml"
    log:
        "logs/gatk/genomicsdbimport.log",
    params:
        intervals=lambda w, input: input.interval_list,
        db_action="create",  # optional
        extra="",  # optional
        java_opts="",  # optional
    threads: 2
    resources:
        mem_mb=lambda wildcards, input: max([input.size_mb * 1.6, 200]),
    wrapper:
        "v7.6.0/bio/gatk/genomicsdbimport"


#####################################
# Genotype the GVCFs
#####################################

rule genotype_gvcfs:
    input:
        genomicsdb="results/genomicsdb",
        # gvcf="calls/all.g.vcf",  # combined gvcf over multiple samples
        # N.B. gvcf or genomicsdb must be specified
        # in the latter case, this is a GenomicsDB data store
        ref="resources/genome.fasta",
    output:
        vcf="results/genotyped/all.vcf.gz",
    # conda:
    #     "envs/variant.yaml"
    log:
        "logs/gatk/genotypegvcfs.log"
    params:
        extra="",  # optional
        java_opts="", # optional
    resources:
        mem_mb=1024
    wrapper:
        "v7.6.0/bio/gatk/genotypegvcfs"


