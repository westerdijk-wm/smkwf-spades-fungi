rule call_variants:
    input:
        bam=get_sample_bams_dedup,
        bai=get_sample_bai_dedup,
        ref="resources/genome.fasta",
        idx="resources/genome.dict",
        # known="resources/variation.noiupac.vcf.gz",
        # tbi="resources/variation.noiupac.vcf.gz.tbi",
    output:
        gvcf=protected("results/called/{sample}.g.vcf.gz"),
    log:
        "logs/gatk/haplotypecaller/{sample}.log",
    params: # Some need to be moved to config
        extra="-G StandardAnnotation -G AS_StandardAnnotation -G StandardHCAnnotation " +
              config["params"]["gatk"]["HaplotypeCaller"] +
              " -sample-name {sample}"       
    threads: 4
    resources:
        mem_mb=1024,
    wrapper:
        "v7.6.0/bio/gatk/haplotypecaller"


