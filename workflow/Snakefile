# filter before extracting FASTA
rule bcf_filter_o_vcf_gz:
    input:
        "results/filtered/all.snvs.selected.vcf.gz",
    output:
        temp("results/msa/all.snvs.filtered.vcf.gz"),
    log:
        "logs/bcftools/filter-msa.log",
    params:
        filter="--SnpGap 3 -e 'QUAL < 1000 || AF=1 || INFO/AF < 0.05 || F_MISSING > 0'",
        extra="",
    wrapper:
        "v8.1.1/bio/bcftools/filter"

rule msa_ref_fasta:
    input:
        "results/msa/all.snvs.filtered.vcf.gz",
    output:
        temp("results/msa/ref.fasta"),
    conda:
        "envs/variant.yaml",
    log:
        "logs/bcftools/filter-msa-ref.log",
    shell:
        """
        printf ">REF\n%s\n" \
        $(bcftools query -f '%REF' {input} | tr -d '\n') > {output} 2> {log}
        """


rule msa_sample_fasta:
    input:
        "results/msa/all.snvs.filtered.vcf.gz",
    output:
        temp("results/msa/{sample}.fasta"),
    conda:
        "envs/variant.yaml",
    log:
        "logs/bcftools/filter-msa-{sample}.log",
    shell:
        """
        printf ">{wildcards.sample}\n%s\n" \
        $(bcftools query -s {wildcards.sample} -f '[%IUPACGT]' {input} | tr -d '\n') > {output} 2> {log}
        """


rule concat_fasta:
    input:
        ref="results/msa/ref.fas",
        samples=expand("results/msa/{sample}.fasta", sample=samples.index)
    output:
        "results/msa/snvs.fas"
    shell:
        """
        cat {input.ref} {input.samples} > {output}
        """


# Phylogeny

rule fasttree:
    input:
        alignment="results/msa/{alnname}.fas",  # Input alignment file
    output:
        tree="results/phylogeny/fasttree-{alnname}.nwk",  # Output tree file
    log:
        "logs/fasttree/fasttree-{alnname}.log",
    params:
        extra="-gtr -gamma -nt",  # Additional arguments
    wrapper:
        "v7.3.0/bio/fasttree"
