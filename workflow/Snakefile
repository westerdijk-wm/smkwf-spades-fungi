##### Modules #####


rule get_fastq_pe_gz:
    output:
        # the wildcard name must be accession, pointing to an SRA number
        "resources/reads/{accession}_1.fastq.gz",
        "resources/reads/{accession}_2.fastq.gz",
    log:
        "logs/fasterq-dump/{accession}.gz.log"
    params:
        extra="--skip-technical"
    threads: 6  # defaults to 6
    wrapper:
        "v9.8.0/bio/sra-tools/fasterq-dump"


# include: "rules/ref.smk"
# skipped variants (vep)

checkpoint genome_faidx:
    input:
        "resources/genome.fasta",
    output:
        "resources/genome.fasta.fai",
    log:
        "logs/genome-faidx.log",
    cache: True
    params:
        extra="",
    wrapper:
        "v8.1.1/bio/samtools/faidx"


rule intervals_from_fai:
    input:
        "resources/genome.fasta.fai",
    output:
        "resources/intervals.list",
    shell:
        "cut -f1 {input} > {output}"


rule genome_dict:
    input:
        "resources/genome.fasta",
    output:
        "resources/genome.dict",
    log:
        "logs/samtools/create_dict.log",
    conda:
        "envs/samtools.yaml"
    cache: True
    shell:
        "samtools dict {input} > {output} 2> {log} "


rule bwa_index:
    input:
        "resources/genome.fasta",
    output:
        idx=multiext("resources/genome.fasta", ".amb", ".ann", ".bwt", ".pac", ".sa"),
    log:
        "logs/bwa_index.log",
    wrapper:
        "v5.10.0/bio/bwa/index"


