rule spades_pe:
    """
    Assembles reads using SPAdes (works only for single lib at the moment)
    """
    input:
        reads=lambda wildcards: [item for sublist in [["results/trimmed/{sample}-{unit}.1.fastq.gz".format(sample=wildcards.sample, unit=u),
                                     "results/trimmed/{sample}-{unit}.2.fastq.gz".format(sample=wildcards.sample, unit=u)]
                                      for u in units.loc[wildcards.sample].unit] for item in sublist]
    output:
        contigs="results/spades/{sample}/contigs.fasta",
        scaffolds="results/spades/{sample}/scaffolds.fasta",
        fastg="results/spades/{sample}/assembly_graph.fastg"
        # "results/assemblies/{sample}/contigs.fasta"
    log:
        "logs/spades/{sample}.log",
    conda:
        "envs/spades.yaml" 
    params:
        input_param=lambda wildcards: " ".join(["--pe{unit}-1 results/trimmed/{sample}-{unit}.1.fastq.gz --pe{unit}-2 results/trimmed/{sample}-{unit}.2.fastq.gz".format(
            sample=wildcards.sample, unit=u) for u in units.loc[wildcards.sample].unit]),
        extra="--careful"
    threads:
        16
    shell:
        "spades.py {params} -t {threads} -o assemblies/{wildcards.sample}"


rule get_organelles:
    input:
        fastg="results/spades/{sample}/assembly_graph.fastg",
    output:
        mt="results/get_organelles/{sample}/fungus_mt.complete.graph1.1.path_sequence.fasta",
        nr="results/get_organelles/{sample}/fungus_nr.complete.graph1.1.path_sequence.fasta",
        csv="results/get_organelles/{sample}/slimmed_assembly_graph.csv",
    log:
        "logs/get_organelles/{sample}.log",
    conda:
        "envs/get_organelles.yaml"
    params:
        targets="fungus_nr,fungus_mt"
    shell:
        """
        get_organelle_from_assembly.py -F {params.targets} -g {input.fastg} -o results/get_organelles/{wildcards.sample} 2> {log}
        """


rule filter_spades_contigs:
    input:
        contigs="results/spades/{sample}/contigs.fasta",
        paths="resutlts/spades/{sample}/contigs.paths",
        csv="results/get_organelles/{sample}/slimmed_assembly_graph.csv",
    output:
        "results/get_organelles/{sample}/filtered-contigs.fasta",
    log:
        "logs/filter_spades/{sample}.log",
    # conda:
    #     "envs/filter_spades.yaml"
    shell:
        """
        perl filter_spades_contigs.pl --contigs {input.contigs} --paths {input.paths} --csv {input.csv} > {output} 2> {log}
        """