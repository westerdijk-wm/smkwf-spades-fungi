# include: "rules/calling.smk"

if "restrict-regions" in config["processing"]:

    rule compose_regions:
        input:
            config["processing"]["restrict-regions"],
        output:
            "results/called/{contig}.regions.bed",
        conda:
            "envs/bedops.yaml"
        shell:
            "bedextract {wildcards.contig} {input} > {output}"


rule call_variants:
    input:
        bam=get_sample_bams_dedup,
        bai=get_sample_bai_dedup,
        ref="resources/genome.fasta",
        idx="resources/genome.dict",
        # known="resources/variation.noiupac.vcf.gz",
        # tbi="resources/variation.noiupac.vcf.gz.tbi",
    output:
        gvcf=protected("results/called/{sample}.g.vcf.gz"),
    log:
        "logs/gatk/haplotypecaller/{sample}.log",
    params: # Some need to be moved to config
        extra="-G StandardAnnotation -G AS_StandardAnnotation -G StandardHCAnnotation " +
              config["params"]["gatk"]["HaplotypeCaller"] +
              " -sample-name {sample}"       
    threads: 4
    resources:
        mem_mb=1024,
    wrapper:
        "v7.6.0/bio/gatk/haplotypecaller"


rule genomics_db_import:
    input:
        gvcfs=expand(
            "results/called/{sample}.g.vcf.gz", sample=samples.index
        ),
        interval_list="resources/intervals.list",
    output:
        db=directory("results/genomicsdb"),
    log:
        "logs/gatk/genomicsdbimport.log",
    params:
        intervals=lambda w, input: input.interval_list,
        db_action="create",  # optional
        extra="",  # optional
        java_opts="",  # optional
    threads: 2
    resources:
        mem_mb=lambda wildcards, input: max([input.size_mb * 1.6, 200]),
    wrapper:
        "v7.6.0/bio/gatk/genomicsdbimport"


